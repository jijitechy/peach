rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives & Identity Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Schema Validators
    function isValidUser(data) {
      return data.id is string
        && data.username is string && data.username.size() <= 200
        && data.name is string && data.name.size() <= 250
        && data.phone is string && data.phone.size() <= 64
        && data.role in ['buyer', 'bidder', 'seller', 'admin']
        && (data.balance is number || data.balance is int);
    }

    function isValidListing(data) {
      return data.id is string
        && data.title is string && data.title.size() <= 250
        && data.category is string && data.category.size() <= 100
        && data.condition is string && data.condition.size() <= 100
        && data.location is string && data.location.size() <= 100
        && (data.currentBid is number || data.currentBid is int)
        && (data.bidsCount is number || data.bidsCount is int)
        && data.sellerId is string && data.sellerId.size() <= 128
        && data.status in ['live', 'completed', 'expired'];
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isSignedIn() && (request.auth.uid == userId || request.auth.token.email == 'admin@gmail.com') && isValidUser(request.resource.data);
      allow delete: if false;
    }

    // Listings Collection rules
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidListing(request.resource.data);
      allow update: if isSignedIn() && isValidListing(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || request.auth.token.email == 'admin@gmail.com');
    }
  }
}
